{
  "@context": {
    "@vocab": "https://schema.org/",
    "traceable": "https://api-evangelist.com/context/traceable/",
    "sec": "https://api-evangelist.com/context/security/",
    "APIEntity": "traceable:APIEntity",
    "id": "schema:identifier",
    "name": "schema:name",
    "entityType": "traceable:entityType",
    "service": "traceable:service",
    "domain": "traceable:domain",
    "method": "traceable:httpMethod",
    "authenticated": "traceable:requiresAuthentication",
    "authType": "traceable:authType",
    "riskScore": "sec:riskScore",
    "isInternal": "traceable:isInternal",
    "discoveryState": "traceable:discoveryState",
    "lastActivity": "schema:dateModified",
    "callVolume": "traceable:callVolume",
    "errorRate": "traceable:errorRate",
    "latencyP99": "traceable:latencyP99",
    "labels": "schema:keywords",
    "attributes": "traceable:attributes",
    "Vulnerability": "sec:Vulnerability",
    "severity": "sec:severity",
    "owaspCategory": "sec:owaspCategory",
    "status": "traceable:vulnerabilityStatus",
    "ThreatActivity": "sec:ThreatActivity",
    "threatActor": "sec:threatActor",
    "attackPattern": "sec:attackPattern",
    "blockedAt": "traceable:blockedAt",
    "SecurityTestSuite": "sec:TestSuite",
    "scan": "sec:scan",
    "MCPTool": "traceable:MCPTool",
    "tool": "traceable:toolName",
    "GraphQLQuery": "traceable:GraphQLQuery",
    "query": "traceable:graphqlQuery",
    "variables": "traceable:queryVariables"
  }
}
